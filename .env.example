# ─────────────────────────────────────────────────────────────────────────────
# Alfred Notification Service — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── [Optional] Application ────────────────────────────────────────────────────
PORT=8300
CORS_ALLOWED_ORIGINS=https://gateway.test

# ── [Optional] mTLS — only when running behind a service mesh ─────────────────
MTLS_ENABLED=false
MTLS_HTTP_PORT=8300
MTLS_HTTPS_PORT=8301
MTLS_SERVER_CERT_PATH=certs/server.pfx
MTLS_SERVER_CERT_PASSWORD=
MTLS_CA_CERT_PATH=certs/ca.crt

# ── [Required] SMTP — email delivery ─────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=<CHANGE_ME>
SMTP_PASSWORD=<CHANGE_ME>
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME="Alfred Notification"

# ── [Optional] Redis queue key ────────────────────────────────────────────────
REDIS_EMAIL_QUEUE_KEY=alfred:notifications:email

# ── [Required] Database — PostgreSQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=<CHANGE_ME>
DB_DATABASE=alfred_notification

# ── [Required] Redis ──────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME>
